# 🔐 Template de Credenciais (NÃO COMMITAR COM CHAVES REAIS)
# Copie este arquivo para 'cloudstack-creds.yaml', preencha e rode kubectl apply, 
# mas NUNCA envie o arquivo com chaves para o GitHub.

apiVersion: v1
kind: Secret
metadata:
  name: cloudstack-creds
  namespace: crossplane-system
type: Opaque
stringData:
  credentials: |
    {
      "api_url": "http://10.0.50.254:8080/client/api",
      "api_key": "SUA_API_KEY",
      "secret_key": "SUA_SECRET_KEY",
      "verify_ssl": false
    }
